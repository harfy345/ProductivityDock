<Window x:Class="ProductivityApp.UI.BlockWindow"
     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:local="clr-namespace:ProductivityApp.UI"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        Background="Black"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <!-- TOP SECTION -->
        <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Grid.Row="0">

            <TextBlock x:Name="MessageText"
                   Text="Focus time active"
                   Foreground="White"
                   FontSize="30"
                   HorizontalAlignment="Center"/>

            <TextBlock x:Name="TimerText"
                   Text="10"
                   Foreground="Gray"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   Margin="10"/>

            <Button Content="Override"
                Width="150"
                Height="40"
                Margin="20"
                Click="Override_Click"/>
        </StackPanel>

        <!-- BOTTOM SECTION (NEW PANEL) -->
        <local:BlockWindowRecommendationPanel Grid.Row="1"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Top"/>
    </Grid>
</Window>